# Path to the Real-ESRGAN binary (either absolute path or available in PATH)
# Windows example: REAL_ESRGAN_PATH=C:\\tools\\realesrgan\\realesrgan-ncnn-vulkan.exe
# Linux example:   REAL_ESRGAN_PATH=/usr/local/bin/realesrgan-ncnn-vulkan
REAL_ESRGAN_PATH=realesrgan-ncnn-vulkan

# Default model name passed to `-n`
REAL_ESRGAN_MODEL=realesrgan-x4plus

# Default scale when UI doesn't send one (2, 3, or 4)
UPSCALER_SCALE=4

# Max runtime for one upscale job
UPSCALER_TIMEOUT_MS=120000

# Temp directory for input/output files
UPSCALER_TMP_DIR=.tmp/upscale
